{
  "permissions": {
    "deny": [
      "Bash(*DELETE *)",
      "Bash(*DROP *)",
      "Bash(*UPDATE *)",
      "Bash(*INSERT *)",
      "Bash(*ALTER *)",
      "Bash(*TRUNCATE *)"
    ],
    "allow": [
      "Bash(npx wrangler d1 execute *)",
      "Bash(npx wrangler kv *)",
      "Bash(npx wrangler tail *)",
      "Bash(pnpm test*)",
      "Bash(pnpm -r typecheck)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/deploy-gate.cjs\"",
            "timeout": 360
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"/opt/homebrew/bin:$PATH\"; jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.md) \"$CLAUDE_PROJECT_DIR/node_modules/.bin/prettier\" --write --prose-wrap never \"$f\";; esac; } 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
