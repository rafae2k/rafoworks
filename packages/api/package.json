{
  "name": "@rafoworks/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "echo 'bundled by wrangler'",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate --name",
    "db:migrate:local": "wrangler d1 migrations apply rafoworks-db --local",
    "db:migrate": "wrangler d1 migrations apply rafoworks-db --remote"
  },
  "dependencies": {
    "@rafoworks/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.5",
    "@cloudflare/workers-types": "^4.20250327.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0",
    "wrangler": "^4.82.1"
  }
}
